{
	"name": "sveltekit-devtools",
	"version": "0.0.0",
	"description": "Vite-powered devtools for SvelteKit",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/node/index.d.ts",
			"import": "./dist/node/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "pnpm clean && pnpm build:client && pnpm build:node",
		"build:client": "vite build --config vite.client.config.ts",
		"build:node": "tsc -p tsconfig.build.json",
		"check": "svelte-check --tsconfig tsconfig.client.json && tsc -p tsconfig.build.json --noEmit",
		"clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
		"lint": "prettier --check .",
		"test": "vitest run"
	},
	"dependencies": {
		"@vitejs/devtools": "^0.3.3",
		"@vitejs/devtools-kit": "^0.3.3",
		"launch-editor": "^2.14.1"
	},
	"peerDependencies": {
		"@sveltejs/kit": ">=2.0.0",
		"typescript": ">=5.3.0",
		"vite": ">=5.0.3"
	},
	"devDependencies": {
		"@fontsource/dm-mono": "^5.2.5",
		"@fontsource/dm-sans": "^5.2.5",
		"@phosphor-icons/core": "^2.1.1",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24.10.1",
		"fuse.js": "^7.4.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^5.9.3",
		"vis-data": "^8.0.4",
		"vis-network": "^10.1.0",
		"vite": "^7.3.0",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.19"
	}
}
