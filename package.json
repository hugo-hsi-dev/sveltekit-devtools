{
	"name": "sveltekit-devtools-monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=20.19",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"build": "pnpm -r --filter='./packages/*' build",
		"check": "pnpm build && pnpm -r check",
		"dev": "pnpm build && pnpm --dir playgrounds/basic dev",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test": "pnpm -r test",
		"changeset:version": "changeset version && git add --all",
		"changeset:publish": "changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"prettier": "^3.7.3",
		"prettier-plugin-svelte": "^4.0.0"
	}
}
